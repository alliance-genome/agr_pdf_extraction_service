# Required — get values from SSM: aws ssm get-parameters-by-path --path /pdfx/
EC2_INSTANCE_ID=
COGNITO_USER_POOL_ID=

# Optional — these have sensible defaults
EC2_REGION=us-east-1
EC2_PORT=5000
COGNITO_REGION=us-east-1
COGNITO_REQUIRED_SCOPE=pdfx-api/extract
IDLE_TIMEOUT_MINUTES=30
MIN_UPTIME_MINUTES=20
STARTUP_TIMEOUT_MINUTES=10
MAX_QUEUED_JOBS=10
ALWAYS_ON_MODE=false

# Queue durability (recommended for production)
QUEUE_BACKEND=memory
QUEUE_S3_BUCKET=
QUEUE_S3_PREFIX=pdfx-proxy-queue
QUEUE_S3_REGION=us-east-1

# Reconciliation / stuck-job handling
STUCK_PENDING_MINUTES=20
RECONCILER_INTERVAL_SECONDS=60
RECONCILER_REQUEUE_ONCE=false

# Deep health + canary probes
HEALTHCHECK_BEARER_TOKEN=
CANARY_INTERVAL_SECONDS=0
CANARY_BEARER_TOKEN=
