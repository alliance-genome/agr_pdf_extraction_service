{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EC2Lifecycle",
      "Effect": "Allow",
      "Action": [
        "ec2:StartInstances",
        "ec2:StopInstances"
      ],
      "Resource": "arn:aws:ec2:${REGION}:${AWS_ACCOUNT_ID}:instance/${EC2_INSTANCE_ID}"
    },
    {
      "Sid": "EC2Describe",
      "Effect": "Allow",
      "Action": "ec2:DescribeInstances",
      "Resource": "*"
    },
    {
      "Sid": "SSMReadPdfxParams",
      "Effect": "Allow",
      "Action": "ssm:GetParameters",
      "Resource": "arn:aws:ssm:${REGION}:${AWS_ACCOUNT_ID}:parameter/pdfx/*"
    },
    {
      "Sid": "S3QueueListBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::${QUEUE_S3_BUCKET}"
    },
    {
      "Sid": "S3QueueReadWriteObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:DeleteObjectVersion"
      ],
      "Resource": "arn:aws:s3:::${QUEUE_S3_BUCKET}/*"
    }
  ]
}
