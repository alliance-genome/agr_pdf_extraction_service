{
  "family": "${TASK_FAMILY}",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "${EXECUTION_ROLE_ARN}",
  "taskRoleArn": "${TASK_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "${CONTAINER_NAME}",
      "image": "${ECR_IMAGE}",
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "QUEUE_BACKEND", "value": "s3"},
        {"name": "QUEUE_S3_BUCKET", "value": "${QUEUE_S3_BUCKET}"},
        {"name": "QUEUE_S3_PREFIX", "value": "${QUEUE_S3_PREFIX}"},
        {"name": "QUEUE_S3_REGION", "value": "${QUEUE_S3_REGION}"},
        {"name": "MIN_UPTIME_MINUTES", "value": "20"},
        {"name": "STUCK_PENDING_MINUTES", "value": "20"},
        {"name": "RECONCILER_INTERVAL_SECONDS", "value": "60"},
        {"name": "RECONCILER_REQUEUE_ONCE", "value": "false"},
        {"name": "ALWAYS_ON_MODE", "value": "false"}
      ],
      "secrets": [
        {"name": "EC2_INSTANCE_ID", "valueFrom": "${SSM_PREFIX}/ec2-instance-id"},
        {"name": "EC2_REGION", "valueFrom": "${SSM_PREFIX}/ec2-region"},
        {"name": "EC2_PORT", "valueFrom": "${SSM_PREFIX}/ec2-port"},
        {"name": "COGNITO_USER_POOL_ID", "valueFrom": "${SSM_PREFIX}/cognito-user-pool-id"},
        {"name": "COGNITO_REGION", "valueFrom": "${SSM_PREFIX}/cognito-region"},
        {"name": "COGNITO_REQUIRED_SCOPE", "valueFrom": "${SSM_PREFIX}/cognito-required-scope"},
        {"name": "COGNITO_ACCEPTED_SCOPES", "valueFrom": "${SSM_PREFIX}/cognito-accepted-scopes"},
        {"name": "COGNITO_ACCEPTED_CLIENT_IDS", "valueFrom": "${SSM_PREFIX}/cognito-accepted-client-ids"},
        {"name": "IDLE_TIMEOUT_MINUTES", "valueFrom": "${SSM_PREFIX}/idle-timeout-minutes"},
        {"name": "STARTUP_TIMEOUT_MINUTES", "valueFrom": "${SSM_PREFIX}/startup-timeout-minutes"},
        {"name": "MAX_QUEUED_JOBS", "valueFrom": "${SSM_PREFIX}/max-queued-jobs"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "${LOG_GROUP}",
          "awslogs-region": "${LOG_REGION}",
          "awslogs-stream-prefix": "proxy"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:80/api/v1/health', timeout=3)\" || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "essential": true
    }
  ]
}
