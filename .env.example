# =============================================================================
# agr_pdf_extraction_service - Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Most settings have sensible defaults in config.py. Only values you want to
# OVERRIDE need to be set here. Secrets (API keys) are the main exception --
# those MUST be set.
# =============================================================================

# ====================
# Secrets (required)
# ====================

# OpenAI API Key (required for LLM-based merge of extraction outputs)
OPENAI_API_KEY=your_openai_api_key_here

# ABC Literature REST API (requires VPN to Alliance network)
# ABC_API_URL=https://stage-literature-rest.alliancegenome.org
# ABC_API_TOKEN=your_abc_bearer_token_here

# ====================
# Optional overrides
# ====================
# Everything below has defaults in config.py. Uncomment to override.

# ---- Cache versioning ----
# Bump this when extractor config changes to invalidate old cached outputs.
# EXTRACTION_CONFIG_VERSION=6

# ---- GROBID ----
# GROBID_URL=http://localhost:8070         # set by docker-compose
# GROBID_REQUEST_TIMEOUT=120               # seconds
# GROBID_INCLUDE_COORDINATES=true
# GROBID_INCLUDE_RAW_CITATIONS=false
# PDFALTO_TIMEOUT_SECONDS=900              # optional native-style evidence only

# ---- Docling ----
# DOCLING_DEVICE=cpu                       # cpu or auto
# DOCLING_RAPIDOCR_BACKEND=onnxruntime     # OCR backend; onnxruntime supports PP-OCRv6 on CPU
# DOCLING_RAPIDOCR_MODEL_TYPE=medium       # PP-OCRv6 model size: small or medium
# DOCLING_RAPIDOCR_DET_LANG=en             # PP-OCRv6 detector language family: en or ch
# DOCLING_RAPIDOCR_REC_LANG=en             # PP-OCRv6 recognizer language family: en or ch
# DOCLING_RAPIDOCR_USE_CUDA=false          # keep OCR on CPU; Docling layout can still use CUDA

# ---- Marker ----
# MARKER_DEVICE=cpu                        # cpu or auto

# ---- LLM (merge) ----
# SOURCE_SELECTION_MODEL=gpt-5.6-terra
# SOURCE_SELECTION_REASONING=medium
# HARD_SELECTION_MODEL=gpt-5.6-sol
# HARD_SELECTION_REASONING=high
# LLM_OPENAI_TIMEOUT_SECONDS=180         # bounded per-request timeout
# LLM_OPENAI_MAX_RETRIES=1               # bounded SDK transport retries
# LLM_COST_ALERT_USD_PER_JOB=2.0          # log-only alert; never truncates work
# IMAGE_TEXT_REVIEW_MODEL=gpt-5.6-luna   # model for text-only image artifact review
# IMAGE_TEXT_REVIEW_REASONING=medium      # reasoning effort for text-only image review

# PDFX_BENCHMARK_MODE=false               # verbose content-free decision/timing evidence for isolated corpus runs

# ---- Storage ----
# CACHE_FOLDER=/app/data/cache
# UPLOAD_FOLDER=/app/data/uploads
# MAX_CONTENT_LENGTH=104857600             # 100MB
# DATABASE_URL=postgresql://pdfx:pdfx@localhost:5432/pdfx

# ---- S3 audit + artifact retention ----
# On EC2: bucket name is read from SSM Parameter Store (/pdfx/audit-s3-bucket).
# For local dev: set AUDIT_S3_BUCKET directly.
# AUDIT_S3_BUCKET=agr-pdf-extraction-benchmark
# AUDIT_S3_PREFIX=pdfx/audit
# AUDIT_FLUSH_ON_EVENT=true               # keep partial audit logs durable during long runs
# IMAGE_URL_TTL_SECONDS=3600
# IMAGE_RETENTION_TTL_SECONDS=604800
# AWS_DEFAULT_REGION=us-east-1

# ---- Celery / Redis ----
# CELERY_BROKER_URL=redis://localhost:6379/0    # set by docker-compose
# CELERY_RESULT_BACKEND=redis://localhost:6379/1 # set by docker-compose
# TASK_SOFT_TIME_LIMIT_SECONDS=1800              # recovery stops before this limit
# TASK_HARD_TIME_LIMIT_SECONDS=2100              # Celery hard kill
# EXTRACTION_FINALIZATION_RESERVE_SECONDS=300    # never spend this reserve on recovery
# HEALTH_BUSY_RUN_MAX_AGE_SECONDS=21600         # max running-row age that can downgrade workers=0 to busy/degraded
