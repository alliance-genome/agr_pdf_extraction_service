# =============================================================================
# agr_pdf_extraction_service - Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Most settings have sensible defaults in config.py. Only values you want to
# OVERRIDE need to be set here. Secrets (API keys) are the main exception --
# those MUST be set.
# =============================================================================

# ====================
# Secrets (required)
# ====================

# OpenAI API Key (required for LLM-based merge of extraction outputs)
OPENAI_API_KEY=your_openai_api_key_here

# ABC Literature REST API (requires VPN to Alliance network)
# ABC_API_URL=https://stage-literature-rest.alliancegenome.org
# ABC_API_TOKEN=your_abc_bearer_token_here

# ====================
# Optional overrides
# ====================
# Everything below has defaults in config.py. Uncomment to override.

# ---- Cache versioning ----
# Bump this when extractor config changes to invalidate old cached outputs.
# EXTRACTION_CONFIG_VERSION=4

# ---- GROBID ----
# GROBID_URL=http://localhost:8070         # set by docker-compose
# GROBID_REQUEST_TIMEOUT=120               # seconds
# GROBID_INCLUDE_COORDINATES=false
# GROBID_INCLUDE_RAW_CITATIONS=false

# ---- Docling ----
# DOCLING_DEVICE=cpu                       # cpu or auto

# ---- Marker ----
# MARKER_DEVICE=cpu                        # cpu or auto
# MARKER_EXTRACT_IMAGES=true              # extracts figures as PNG (default: true)

# ---- LLM (merge) ----
# LLM_MODEL=gpt-5.2
# LLM_CONFLICT_BATCH_SIZE=10             # segments per conflict-resolution batch
# LLM_CONFLICT_MAX_WORKERS=4             # parallel conflict-resolution requests
# LLM_CONFLICT_RETRY_ROUNDS=2            # retries for unresolved segment IDs only

# ---- Consensus pipeline ----
# CONSENSUS_ENABLED=true                   # set to false to disable consensus pipeline
# CONSENSUS_NEAR_THRESHOLD=0.92            # token_set_ratio threshold for AGREE_NEAR
# CONSENSUS_LEVENSHTEIN_THRESHOLD=0.90     # normalized Levenshtein threshold for AGREE_NEAR
# CONSENSUS_CONFLICT_RATIO_FALLBACK=0.4    # conflict ratio above this triggers full-LLM fallback
# CONSENSUS_CONFLICT_RATIO_TEXTUAL_FALLBACK=0.4   # fallback threshold for textual blocks
# CONSENSUS_CONFLICT_RATIO_STRUCTURED_FALLBACK=0.85  # fallback threshold for tables/equations
# CONSENSUS_LOCALIZED_CONFLICT_SPAN_MAX=0.35      # conflicts spanning <= this fraction are "localized"
# CONSENSUS_LOCALIZED_CONFLICT_RELIEF=0.15        # threshold relief added when conflicts are localized
# CONSENSUS_LOCALIZED_CONFLICT_MAX_BLOCKS=25      # max conflict blocks eligible for localized relief
# CONSENSUS_LAYERED_ENABLED=true                  # enable layered conflict resolver (median-source + LLM batch)
# CONSENSUS_LAYERED_MEDIUM_SIM_THRESHOLD=0.60    # min similarity for 3+-source median-source (below = LLM)
# CONSENSUS_ALIGNMENT_ANCHOR_MAX_HEADING_LEVEL=2 # only H1/H2 headings become partition anchors (default: 2)
# CONSENSUS_MEDIAN_SOURCE_MAX_MICRO_CONFLICTS=20 # segments with more micro-conflicts skip median-source → LLM
# CONSENSUS_ALIGNMENT_CONFIDENCE_MIN=0.5  # alignment confidence below this fails the extraction
# CONSENSUS_ALWAYS_ESCALATE_TABLES=false   # set true to always send tables/equations to LLM

# ---- Storage ----
# CACHE_FOLDER=/app/data/cache
# UPLOAD_FOLDER=/app/data/uploads
# MAX_CONTENT_LENGTH=104857600             # 100MB
# DATABASE_URL=postgresql://pdfx:pdfx@localhost:5432/pdfx

# ---- S3 audit + artifact retention ----
# On EC2: bucket name is read from SSM Parameter Store (/pdfx/audit-s3-bucket).
# For local dev: set AUDIT_S3_BUCKET directly.
# AUDIT_S3_BUCKET=agr-pdf-extraction-benchmark
# AUDIT_S3_PREFIX=pdfx/audit
# AWS_DEFAULT_REGION=us-east-1

# ---- Celery / Redis ----
# CELERY_BROKER_URL=redis://localhost:6379/0    # set by docker-compose
# CELERY_RESULT_BACKEND=redis://localhost:6379/1 # set by docker-compose
